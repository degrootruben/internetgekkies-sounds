{
  "description": "Plays a random Internetgekkies sound clip on Stop and Notification events",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/play-random.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/play-random.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
